# KRONOS Environment Configuration
# Copy to: kronos/docker/.env
# Generate SECRET_KEY:        python3 -c "import secrets; print(secrets.token_hex(32))"
# Generate OWNER_PASSWORD_HASH: python3 scripts/hash_password.py
#
# IMPORTANT: bcrypt hashes contain $ signs.
# scripts/start.bat and hash_password.bat automatically escape them as $$
# which Docker Compose converts back to $ when passing to containers.
# If you edit .env manually, make sure every $ in the hash is written as $$
# Example: $2b$12$abc... must be written as $$2b$$12$$abc...

SECRET_KEY=replace-with-output-of-python3-secrets-token-hex-32
OWNER_USERNAME=admin
OWNER_PASSWORD_HASH=replace-with-output-of-hash_password-script
