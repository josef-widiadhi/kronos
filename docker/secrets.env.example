# KRONOS Secrets File
# Copy to: docker/secrets.env
# This file is loaded by Docker Compose as env_file - values are passed RAW
# to the container with NO variable substitution, so bcrypt $ signs are safe.
#
# Generate your hash: python3 scripts/hash_password.py
# Then paste the output exactly as shown below.

SECRET_KEY=REPLACE_ME_run_hash_password_script
OWNER_USERNAME=admin
OWNER_PASSWORD_HASH=REPLACE_ME_run_hash_password_script

# Optional: folder on your host to watch for documents (Folder Watcher worker)
# Windows example: KRONOS_WATCH_FOLDER=D:/kronos-docs
# Linux/Mac:       KRONOS_WATCH_FOLDER=/home/user/kronos-docs
# KRONOS_WATCH_FOLDER=
